<Window x:Class="NetDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetDashboard" Height="960" Width="980"
        Icon="pack://application:,,,/RayStudio.ico"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E2E8F0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CardHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnMail"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#7C3AED"/>
        </Style>
        <Style x:Key="BtnDomain" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style x:Key="BtnConn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#0D9488"/>
        </Style>
        <Style x:Key="BtnSystem" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#475569"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="#162033" CornerRadius="8,8,0,0"
                                Padding="16,9" Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Console" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9FE88D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
        <Style x:Key="Busy" TargetType="TextBlock">
            <Setter Property="Text" Value="⏳ läuft…"/>
            <Setter Property="Foreground" Value="#FBBF24"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel mit Logo -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="White" CornerRadius="8" Padding="6" Margin="0,0,14,0" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/RayStudio.png" Width="52" Height="52" Stretch="Uniform"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="NetDashboard" Foreground="#F1F5F9" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Netzwerk- &amp; Mail-Toolkit  ·  by RayStudio" Foreground="#64748B" FontSize="13"/>
            </StackPanel>
        </StackPanel>

        <!-- Resolver-Auswahl (zentral, gilt für alle) -->
        <Border Grid.Row="1" Background="#162033" CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="DNS-Resolver für den Vergleich" Style="{StaticResource CardTitle}"/>
                <TextBlock Style="{StaticResource CardHint}"
                           Text="Mehrere anhaken = Kontrolle. Fällt ein Dienst aus oder antwortet falsch, erkennst du es durch den Vergleich. Gilt für Mail-Check und DNS-Check."/>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkGoogle" Content="Google (8.8.8.8)" IsChecked="True"/>
                    <CheckBox x:Name="ChkCloudflare" Content="Cloudflare (1.1.1.1)" IsChecked="True"/>
                    <CheckBox x:Name="ChkQuad9" Content="Quad9 (9.9.9.9)" IsChecked="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">

            <!-- TAB: Mail-Check -->
            <TabItem Header="📧 Mail-Check">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Mail-Einstellungen herausfinden" Style="{StaticResource CardTitle}"/>
                            <TextBlock Style="{StaticResource CardHint}"
                                       Text="Du kennst nur deine E-Mail-Adresse, aber nicht die Server-Einstellungen? Adresse eingeben und auf 'Prüfen' klicken – das Tool findet den Mailserver, erkennt den Anbieter und zeigt die passenden IMAP-/SMTP-Werte."/>
                            <TextBlock Text="E-Mail-Adresse" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MailEmailInput" Grid.Column="0" Text="name@firma.ch" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Style="{StaticResource BtnMail}" Margin="0"
                                        Content="✓ Prüfen" Click="MailCheck_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="MailOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="MailBusy" Style="{StaticResource Busy}"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Content="📋 Kopieren" Tag="{Binding ElementName=MailOutput}" Click="Copy_Click"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0" Content="🗑 Leeren" Tag="{Binding ElementName=MailOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB: DNS-Check -->
            <TabItem Header="🔍 DNS-Check">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="DNS-Einträge prüfen (für Support)" Style="{StaticResource CardTitle}"/>
                            <TextBlock Style="{StaticResource CardHint}"
                                       Text="Domain oder IP eingeben und Abfrage wählen. Läuft über alle oben ausgewählten Resolver – so siehst du sofort, ob alle dasselbe liefern."/>
                            <TextBlock Text="Domain oder IP-Adresse" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="HostInput" Text="example.com" Margin="0,0,0,12"/>
                            <WrapPanel>
                                <Button Style="{StaticResource BtnDomain}" Tag="A"     Content="IPv4 (A)"        Click="DnsType_Click" ToolTip="IPv4-Adresse der Domain."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="AAAA"  Content="IPv6 (AAAA)"     Click="DnsType_Click" ToolTip="IPv6-Adresse der Domain."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="MX"    Content="Mailserver (MX)" Click="DnsType_Click" ToolTip="Welche Server E-Mails annehmen."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="TXT"   Content="Text (TXT)"      Click="DnsType_Click" ToolTip="z. B. SPF/DKIM."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="NS"    Content="Nameserver (NS)" Click="DnsType_Click" ToolTip="Zuständige DNS-Server."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="CNAME" Content="Alias (CNAME)"   Click="DnsType_Click" ToolTip="Verweis auf andere Domain."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="SOA"   Content="Zonen-Info (SOA)" Click="DnsType_Click" ToolTip="Verwaltungsdaten der Zone."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="ALL"   Content="Alle Records"    Click="DnsType_Click" ToolTip="Alle Einträge auf einmal."/>
                                <Button Style="{StaticResource BtnDomain}" Tag="PTR"   Content="Reverse (PTR)"   Click="DnsType_Click" ToolTip="Name zu einer IP-Adresse."/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="DnsOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="DnsBusy" Style="{StaticResource Busy}"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Content="📋 Kopieren" Tag="{Binding ElementName=DnsOutput}" Click="Copy_Click"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0" Content="🗑 Leeren" Tag="{Binding ElementName=DnsOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB: Verbindung -->
            <TabItem Header="🔌 Verbindung">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Erreichbarkeit &amp; Ports testen" Style="{StaticResource CardTitle}"/>
                            <TextBlock Style="{StaticResource CardHint}"
                                       Text="Prüft, ob ein Ziel antwortet (Ping), ob ein Port offen ist (443 = HTTPS, 993 = IMAP, 587 = SMTP) und welchen Weg die Daten nehmen (Route)."/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Ziel (Domain oder IP)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TargetInput" Text="example.com"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="PortInput" Text="443"/>
                                </StackPanel>
                            </Grid>
                            <WrapPanel>
                                <Button Style="{StaticResource BtnConn}" Content="Ping (Erreichbarkeit)" Click="Ping_Click" ToolTip="Antwortet das Ziel?"/>
                                <Button Style="{StaticResource BtnConn}" Content="Port-Test" Click="PortTest_Click" ToolTip="Ist der angegebene Port offen?"/>
                                <Button Style="{StaticResource BtnConn}" Content="Route / Tracert" Click="TraceRoute_Click" ToolTip="Weg der Datenpakete (dauert etwas)."/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="ConnOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="ConnBusy" Style="{StaticResource Busy}"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Content="📋 Kopieren" Tag="{Binding ElementName=ConnOutput}" Click="Copy_Click"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0" Content="🗑 Leeren" Tag="{Binding ElementName=ConnOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB: Mein System -->
            <TabItem Header="💻 Mein System">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Infos über deinen PC &amp; dein Netzwerk" Style="{StaticResource CardTitle}"/>
                            <TextBlock Style="{StaticResource CardHint}" Text="Keine Eingabe nötig – einfach auf eine Schaltfläche klicken."/>
                            <WrapPanel>
                                <Button Style="{StaticResource BtnSystem}" Content="IP-Konfiguration" Click="IpConfig_Click" ToolTip="Deine eigenen Netzwerk-Adressen."/>
                                <Button Style="{StaticResource BtnSystem}" Content="Aktive DNS-Server" Click="DnsServers_Click" ToolTip="Welche DNS-Server dein PC nutzt."/>
                                <Button Style="{StaticResource BtnSystem}" Content="DNS-Cache anzeigen" Click="DnsCacheShow_Click" ToolTip="Zwischengespeicherte DNS-Einträge."/>
                                <Button Style="{StaticResource BtnSystem}" Content="DNS-Cache leeren" Click="DnsCacheFlush_Click" ToolTip="Hilft bei DNS-Problemen."/>
                                <Button Style="{StaticResource BtnSystem}" Content="ARP-Tabelle" Click="Arp_Click" ToolTip="Geräte im lokalen Netz."/>
                                <Button Style="{StaticResource BtnSystem}" Content="Routing-Tabelle" Click="Route_Click" ToolTip="Wie dein PC Pakete weiterleitet."/>
                                <Button Style="{StaticResource BtnSystem}" Content="Öffentliche IP" Click="PublicIp_Click" ToolTip="Deine Internet-IP von außen."/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="SysOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="SysBusy" Style="{StaticResource Busy}"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Content="📋 Kopieren" Tag="{Binding ElementName=SysOutput}" Click="Copy_Click"/>
                                <Button Style="{StaticResource BtnSystem}" Margin="0" Content="🗑 Leeren" Tag="{Binding ElementName=SysOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB: Hilfe -->
            <TabItem Header="ℹ️ Hilfe">
                <Border Background="#162033" CornerRadius="10" Padding="16" Margin="0,8,0,0">
                    <TextBlock Foreground="#CBD5E1" FontSize="13" TextWrapping="Wrap">
                        <Run FontWeight="Bold" Foreground="#F1F5F9" Text="Warum mehrere DNS-Resolver?"/><LineBreak/>
                        DNS ist das „Telefonbuch" des Internets. Es gibt mehrere öffentliche Auskünfte (Resolver):
                        Google (8.8.8.8), Cloudflare (1.1.1.1) und Quad9 (9.9.9.9). Das Tool fragt mehrere gleichzeitig und vergleicht.<LineBreak/>
                        • Alle gleich → alles in Ordnung.<LineBreak/>
                        • Unterschiede → Umstellung läuft, ein Resolver hat ein Problem, oder ein Eintrag ist veraltet.<LineBreak/>
                        Fällt ein Resolver aus, siehst du dank der anderen trotzdem ein Ergebnis.<LineBreak/><LineBreak/>
                        <Run FontWeight="Bold" Foreground="#F1F5F9" Text="MX / SPF kurz erklärt:"/><LineBreak/>
                        MX = die Server, die E-Mails für eine Domain annehmen. SPF = legt fest, welche Server im Namen der Domain senden dürfen (Schutz vor Fälschungen).
                    </TextBlock>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>