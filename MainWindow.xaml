<Window x:Class="NetDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetDashboard" Height="960" Width="980"
        Icon="pack://application:,,,/RayStudio.ico"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E2E8F0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CardHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnMail"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#7C3AED"/>
        </Style>
        <Style x:Key="BtnDomain" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style x:Key="BtnConn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#0D9488"/>
        </Style>
        <Style x:Key="BtnSystem" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#475569"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="#162033" CornerRadius="8,8,0,0"
                                Padding="16,9" Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Console" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9FE88D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
        <Style x:Key="Busy" TargetType="TextBlock">
            <Setter Property="Text" Value="⏳ …"/>
            <Setter Property="Foreground" Value="#FBBF24"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel mit Logo + Sprachumschalter -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Background="White" CornerRadius="8" Padding="6" Margin="0,0,14,0" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/RayStudio.png" Width="52" Height="52" Stretch="Uniform"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="NetDashboard" Foreground="#F1F5F9" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock x:Name="Subtitle" Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🌐" FontSize="16" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="LangSelector" Width="130" Height="32" VerticalAlignment="Center"
                          FontSize="13" SelectionChanged="LangSelector_SelectionChanged">
                    <ComboBoxItem Tag="de" Content="Deutsch"/>
                    <ComboBoxItem Tag="en" Content="English"/>
                    <ComboBoxItem Tag="fr" Content="Français"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Resolver-Auswahl -->
        <Border Grid.Row="1" Background="#162033" CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="ResolverTitle" Style="{StaticResource CardTitle}"/>
                <TextBlock x:Name="ResolverHint" Style="{StaticResource CardHint}"/>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkGoogle" Content="Google (8.8.8.8)" IsChecked="True"/>
                    <CheckBox x:Name="ChkCloudflare" Content="Cloudflare (1.1.1.1)" IsChecked="True"/>
                    <CheckBox x:Name="ChkQuad9" Content="Quad9 (9.9.9.9)" IsChecked="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">

            <TabItem x:Name="TabMail">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="MailCardTitle" Style="{StaticResource CardTitle}"/>
                            <TextBlock x:Name="MailCardHint" Style="{StaticResource CardHint}"/>
                            <TextBlock x:Name="MailLabel" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MailEmailInput" Grid.Column="0" Text="name@firma.ch" Margin="0,0,8,0"/>
                                <Button x:Name="MailCheckBtn" Grid.Column="1" Style="{StaticResource BtnMail}" Margin="0" Click="MailCheck_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="MailOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="MailBusy" Style="{StaticResource Busy}"/>
                                <Button x:Name="MailCopy" Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Tag="{Binding ElementName=MailOutput}" Click="Copy_Click"/>
                                <Button x:Name="MailClear" Style="{StaticResource BtnSystem}" Margin="0" Tag="{Binding ElementName=MailOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabDns">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="DnsCardTitle" Style="{StaticResource CardTitle}"/>
                            <TextBlock x:Name="DnsCardHint" Style="{StaticResource CardHint}"/>
                            <TextBlock x:Name="DnsLabel" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="HostInput" Text="example.com" Margin="0,0,0,12"/>
                            <WrapPanel>
                                <Button x:Name="BtnA"     Style="{StaticResource BtnDomain}" Tag="A"     Click="DnsType_Click"/>
                                <Button x:Name="BtnAAAA"  Style="{StaticResource BtnDomain}" Tag="AAAA"  Click="DnsType_Click"/>
                                <Button x:Name="BtnMX"    Style="{StaticResource BtnDomain}" Tag="MX"    Click="DnsType_Click"/>
                                <Button x:Name="BtnTXT"   Style="{StaticResource BtnDomain}" Tag="TXT"   Click="DnsType_Click"/>
                                <Button x:Name="BtnNS"    Style="{StaticResource BtnDomain}" Tag="NS"    Click="DnsType_Click"/>
                                <Button x:Name="BtnCNAME" Style="{StaticResource BtnDomain}" Tag="CNAME" Click="DnsType_Click"/>
                                <Button x:Name="BtnSOA"   Style="{StaticResource BtnDomain}" Tag="SOA"   Click="DnsType_Click"/>
                                <Button x:Name="BtnALL"   Style="{StaticResource BtnDomain}" Tag="ALL"   Click="DnsType_Click"/>
                                <Button x:Name="BtnPTR"   Style="{StaticResource BtnDomain}" Tag="PTR"   Click="DnsType_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="DnsOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="DnsBusy" Style="{StaticResource Busy}"/>
                                <Button x:Name="DnsCopy" Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Tag="{Binding ElementName=DnsOutput}" Click="Copy_Click"/>
                                <Button x:Name="DnsClear" Style="{StaticResource BtnSystem}" Margin="0" Tag="{Binding ElementName=DnsOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabConn">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="ConnCardTitle" Style="{StaticResource CardTitle}"/>
                            <TextBlock x:Name="ConnCardHint" Style="{StaticResource CardHint}"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock x:Name="ConnTargetLabel" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TargetInput" Text="example.com"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock x:Name="PortLabel" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="PortInput" Text="443"/>
                                </StackPanel>
                            </Grid>
                            <WrapPanel>
                                <Button x:Name="BtnPing" Style="{StaticResource BtnConn}" Click="Ping_Click"/>
                                <Button x:Name="BtnPort" Style="{StaticResource BtnConn}" Click="PortTest_Click"/>
                                <Button x:Name="BtnTrace" Style="{StaticResource BtnConn}" Click="TraceRoute_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="ConnOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="ConnBusy" Style="{StaticResource Busy}"/>
                                <Button x:Name="ConnCopy" Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Tag="{Binding ElementName=ConnOutput}" Click="Copy_Click"/>
                                <Button x:Name="ConnClear" Style="{StaticResource BtnSystem}" Margin="0" Tag="{Binding ElementName=ConnOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabSys">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="160"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#162033" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="SysCardTitle" Style="{StaticResource CardTitle}"/>
                            <TextBlock x:Name="SysCardHint" Style="{StaticResource CardHint}"/>
                            <WrapPanel>
                                <Button x:Name="BtnIpcfg" Style="{StaticResource BtnSystem}" Click="IpConfig_Click"/>
                                <Button x:Name="BtnDnsSrv" Style="{StaticResource BtnSystem}" Click="DnsServers_Click"/>
                                <Button x:Name="BtnCacheShow" Style="{StaticResource BtnSystem}" Click="DnsCacheShow_Click"/>
                                <Button x:Name="BtnCacheFlush" Style="{StaticResource BtnSystem}" Click="DnsCacheFlush_Click"/>
                                <Button x:Name="BtnArp" Style="{StaticResource BtnSystem}" Click="Arp_Click"/>
                                <Button x:Name="BtnRoute" Style="{StaticResource BtnSystem}" Click="Route_Click"/>
                                <Button x:Name="BtnPublicIp" Style="{StaticResource BtnSystem}" Click="PublicIp_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#0B1220" CornerRadius="10" Padding="2" Margin="0,12,0,0">
                        <Grid>
                            <TextBox x:Name="SysOutput" Style="{StaticResource Console}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0">
                                <TextBlock x:Name="SysBusy" Style="{StaticResource Busy}"/>
                                <Button x:Name="SysCopy" Style="{StaticResource BtnSystem}" Margin="0,0,8,0" Tag="{Binding ElementName=SysOutput}" Click="Copy_Click"/>
                                <Button x:Name="SysClear" Style="{StaticResource BtnSystem}" Margin="0" Tag="{Binding ElementName=SysOutput}" Click="Clear_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabHelp">
                <Border Background="#162033" CornerRadius="10" Padding="16" Margin="0,8,0,0">
                    <TextBlock x:Name="HelpText" Foreground="#CBD5E1" FontSize="13" TextWrapping="Wrap"/>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>